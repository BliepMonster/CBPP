import "examples/libs/err.cbpp";
import "examples/libs/io.cbpp";
import "examples/libs/num.cbpp";

struct Vec2 {
    x: byte;
    y: byte;
}
mfn _Vec2(x: byte, y: byte) -> Vec2 {
    var vec = _Vec2();
    vec.x = x;
    vec.y = y;
    return vec;
}
mfn _add(a: Vec2, b: Vec2) -> Vec2: _Vec2(a.x+b.x, a.y+b.y);
var vec = _Vec2(1, 2)+_Vec2(2, 3);
printv(vec.x);
print ", ";
printv(vec.y);