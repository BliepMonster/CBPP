import "examples/libs/err.cbpp";
import "examples/libs/io.cbpp";
struct Vector2 {
    x: byte;
    y: byte;
}
struct short {
    a: byte;
    b: byte;
}
mfn add(a: short, b: short) -> short {
    var new = _short();
    new.a = a.a + b.a;
    new.b = a.b + b.b;
    return new;
}
add(_short(), _short());